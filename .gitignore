# =========================================================================
# DevHub 2.0 - Production-Grade .gitignore (DevSecOps Aligned)
# =========================================================================

# -------------------------------------------------------------------------
# 1. SECURITY & SENSITIVE INFORMATION (Zero Leakage Policy)
# -------------------------------------------------------------------------
# Environment files containing local credentials, API tokens, and JWT secrets
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.env

# Cryptographic assets, keystores, and private keys
*.pem
*.key
*.pub
*.jks
*.p12
*.pfx
*.keystore
*.der

# Sensitive configuration file exceptions
# Prevents accidental commits of database passwords or mail configurations
**/backend/src/main/resources/application-local.properties
**/backend/src/main/resources/application-prod.properties
**/backend/src/main/resources/application-secure.properties
secret.yaml
*secret*

# -------------------------------------------------------------------------
# 2. BACKEND (Spring Boot / Maven)
# -------------------------------------------------------------------------
# Compiled class files
*.class

# Log files
*.log
**/logs/
**/backend/target/
**/backend/bin/

# Crash dumps
hs_err_pid*
replay_pid*

# Maven local wrapper configurations/caches
.mvn/wrapper/maven-wrapper.jar
.maven/

# -------------------------------------------------------------------------
# 3. FRONTEND (React / Vite / Node)
# -------------------------------------------------------------------------
# Package manager caches & dependencies
**/node_modules/
.npm/
.yarn/
.pnpm-store/

# Build outputs
**/frontend/dist/
**/frontend/build/
**/frontend/out/

# Log files generated by node package managers
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Editor/Lint caches
.eslintcache
.stylelintcache
.prettiercache
.vite-cache/

# -------------------------------------------------------------------------
# 4. OPERATING SYSTEMS & SYSTEM CACHES
# -------------------------------------------------------------------------
# macOS specific metadata files
.DS_Store
.AppleDouble
.LSOverride
._*
.DocumentRevisions-V100
.fseventsd
.Spotlight-V100
.TemporaryItems
.Trashes
.VolumeIcon.icns
.com.apple.timemachine.donotpresent

# Windows specific thumbnail and desktop files
Thumbs.db
ehthumbs.db
desktop.ini
$RECYCLE.BIN/
*.cab
*.msi
*.msm
*.msp

# -------------------------------------------------------------------------
# 5. IDEs & WORKSPACES
# -------------------------------------------------------------------------
# IntelliJ IDEA
.idea/
*.iml
*.iws
*.ipr
out/

# Eclipse
.metadata/
.classpath
.project
.settings/
*.launch

# NetBeans
**/nbproject/private/
**/nbbuild/
**/dist/
**/nbdist/
.nb-gradle/

# Visual Studio Code
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
.history/
*.code-workspace

# -------------------------------------------------------------------------
# 6. TERRAFORM / INFRASTRUCTURE-AS-CODE (Zero State Leakage Policy)
# -------------------------------------------------------------------------
# Local & remote state files - can contain plaintext secrets, IPs, ARNs
**/terraform/.terraform/
**/terraform/*.tfstate
**/terraform/*.tfstate.*
**/terraform/*.tfstate.backup

# Variable files with real/sensitive values (commit only *.tfvars.example)
**/terraform/*.tfvars
**/terraform/*.tfvars.json
!**/terraform/*.tfvars.example
**/[Tt]erraform/.terraform/
**/[Tt]erraform/*.tfstate
**/[Tt]erraform/*.tfstate.*
**/[Tt]erraform/*.tfvars
!**/[Tt]erraform/*.tfvars.example
**/[Tt]erraform/*.tfplan
# Plan output files - can contain sensitive resource attributes
**/terraform/*.tfplan
**/terraform/tfplan
**/terraform/crash.log
**/terraform/crash.*.log

# Provider plugin cache & lock override files
**/terraform/.terraform.lock.hcl.bak
**/terraform/override.tf
**/terraform/override.tf.json
**/terraform/*_override.tf
**/terraform/*_override.tf.json

# CLI config that may store credentials/tokens
.terraformrc
terraform.rc

# Kubeconfig generated by `aws eks update-kubeconfig` - contains cluster auth
kubeconfig
**/kubeconfig
*.kubeconfig


k8s/manifests/main.yaml
!k8s/manifests/main.yaml.example